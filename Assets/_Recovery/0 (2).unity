  m_Script: {fileID: 11500000, guid: e593d05d9d6204189b4f9ab3922f88cb, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ShopperChat
  chatText: {fileID: 1116676931}
  nameText: {fileID: 1448445954}
  displayDuration: 2
  fadeDuration: 0.5
  punchDuration: 0.5
  punchStrength: {x: 0.2, y: 0.2, z: 0}
  punchVibrato: 10
  typingSpeed: 0.05
  firstEncounterMessages:
  - "\uC548\uB155? \uCC98\uC74C \uBCF4\uB294 \uC5BC\uAD74\uC774\uB124!"
  - "\uBC18\uAC00\uC6CC! \uB09C \uC774 \uAD6C\uC5ED \uCD5C\uACE0\uC758 \uC0C1\uC778\uC774\uC57C!"
  - "\uC624, \uC0C8\uB85C\uC6B4 \uC190\uB2D8 \uB4F1\uC7A5!"
  welcomeMessages:
  - "\uC5B4\uC11C \uC640! \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC5C8\uC5B4!"
  - "\uC548\uB155! \uC624\uB298\uC740 \uBB50\uAC00 \uD544\uC694\uD574?"
  - "\uC9DC\uC794! \uB0B4\uAC00 \uC654\uC5B4!"
  buyPieceMessages:
  - "\uD0C1\uC6D4\uD55C \uC120\uD0DD\uC774\uC57C!"
  - "\uADF8\uAC70 \uC9C4\uC9DC \uAFC0\uD15C\uC774\uB77C\uAD6C!"
  - "\uD5E4\uD5F7, \uACE0\uB9C8\uC6CC!"
  buyArtifactMessages:
  - "\uC6B0\uC640, \uC774\uAC70 \uC9C4\uC9DC \uADC0\uD55C \uAC70\uC57C!"
  - "\uB108\uD55C\uD14C \uB531 \uC5B4\uC6B8\uB9B0\uB2E4!"
  - "\uAC15\uB825\uD55C \uD798\uC774 \uB290\uAEF4\uC9C0\uC9C0?"
  noMoneyMessages:
  - "\uC5B4\uB77C? \uB3C8\uC774 \uC880 \uBAA8\uC790\uB780 \uAC83 \uAC19\uC740\uB370?"
  - "\uACF5\uC9DC\uB294 \uC548 \uB3FC~"
  - "\uB3C8 \uB354 \uBAA8\uC544\uC640\uC57C\uACA0\uB2E4!"
  inventoryFullMessages:
  - "\uAC00\uBC29\uC774 \uB108\uBB34 \uBB34\uAC70\uC6CC \uBCF4\uC5EC!"
  - "\uC790\uB9AC\uAC00 \uC5C6\uC5B4\uC11C \uBABB \uAC00\uC838\uAC00\uACA0\uB124."
  - "\uBE44\uC6B0\uACE0 \uB2E4\uC2DC \uC640!"
  rerollMessages:
  - "\uC0C8\uB85C\uC6B4 \uAC78 \uBCF4\uC5EC\uC904\uAC8C!"
  - "\uC774\uBC88\uC5D4 \uBB50\uAC00 \uB098\uC62C\uAE4C?"
  - "\uAE30\uB300\uD574 \uBD10!"
  leaveMessages:
  - "\uC798 \uAC00! \uB610 \uBD10!"
  - "\uB2E4\uCE58\uC9C0 \uB9D0\uACE0!"
  - "\uC751\uC6D0\uD560\uAC8C!"
